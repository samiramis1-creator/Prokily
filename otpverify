body {
  font-family: Arial, sans-serif;
  background: #f9f9f9;
  text-align: center;
  padding: 20px;
  direction: ltr;
}

/* ── Top bar ── */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #0097A7;
  padding: 10px 14px;
  margin: -20px -20px 0 -20px;
}

.top-bar-btn {
  background: rgba(255,255,255,0.18);
  border: 1px solid rgba(255,255,255,0.5);
  color: #fff;
  padding: 5px 13px;
  border-radius: 20px;
  cursor: pointer;
  font-size: 13px;
  font-weight: bold;
  transition: background 0.2s;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 5px;
}
.top-bar-btn:hover { background: rgba(255,255,255,0.32); }

.top-bar-title {
  color: #fff;
  font-size: 17px;
  font-weight: bold;
}

.instructions {
  font-size: 16px;
  margin: 24px 0 30px;
  line-height: 1.6;
  padding: 0 10px;
}

/* ── OTP inputs ── */
.pin-container {
  display: flex;
  justify-content: center;
  direction: ltr;   /* toujours LTR */
  gap: 15px;
  margin-bottom: 25px;
}

.pin-input {
  width: 48px;
  height: 52px;
  font-size: 24px;
  text-align: center;
  border: none;
  border-bottom: 2px solid #000;
  outline: none;
  background: transparent;
  direction: ltr;
}

.pin-input:focus { border-bottom: 2px solid #0097A7; }

/* ── Timer ── */
.expire-text {
  font-size: 14px;
  margin-bottom: 5px;
  font-weight: bold;
}

.timer {
  font-size: 16px;
  margin-bottom: 20px;
  color: #333;
}

.resend {
  color: #007BFF;
  text-decoration: underline;
  cursor: pointer;
  font-size: 14px;
  margin-top: 20px;
  background: none;
  border: none;
  padding: 0;
}
.resend:hover { color: #0056b3; }

/* ── Logo ── */
.logo {
  margin-top: 20px;
  width: 170px;
  height: auto;
  opacity: 0.9;
}

/* ── Verify button ── */
.verify-btn {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background-color: #FFC107;
  color: #000;
  padding: 15px;
  font-size: 18px;
  font-weight: bold;
  border: none;
  cursor: pointer;
  transition: transform 0.25s ease, background 0.2s;
  z-index: 1000;
}
.verify-btn:hover { background-color: #FFD54F; }
.verify-btn:disabled {
  background-color: #ccc;
  cursor: not-allowed;
}

/* ── Spinner ── */
.spinner {
  margin: 20px auto;
  width: 24px; height: 24px;
  border: 4px solid #FFD54F;
  border-top: 4px solid transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin { 100% { transform: rotate(360deg); } }

/* ── Loader overlay ── */
#loader-overlay {
  display: none;
  position: fixed;
  top: 0; left: 0;
  width: 100vw; height: 100vh;
  background: rgba(0,0,0,0.8);
  z-index: 9999;
  justify-content: center;
  align-items: center;
}
#loader-overlay.active { display: flex; }
#loader-overlay .spinner {
  border: 6px solid #FFC107;
  border-top: 6px solid transparent;
  width: 50px; height: 50px;
}

/* ── Modal ── */
#modal-alert {
  display: none;
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0,0,0,0.6);
  z-index: 10000;
  justify-content: center;
  align-items: center;
}
.modal-box {
  background: white;
  padding: 24px 28px;
  border-radius: 12px;
  text-align: center;
  max-width: 88%;
  box-shadow: 0 8px 30px rgba(0,0,0,0.3);
}
.modal-box p {
  font-size: 16px;
  color: #333;
  margin-bottom: 16px;
  line-height: 1.6;
  white-space: pre-line;
}
.modal-box button {
  background-color: #0097A7;
  color: white;
  border: none;
  padding: 9px 22px;
  border-radius: 5px;
  cursor: pointer;
  font-size: 15px;
}
.modal-box button:hover { background-color: #00838F; }

/* ── Guard overlay (accès direct) ── */
#guard-overlay {
  display: none;
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0,0,0,0.88);
  z-index: 99999;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 16px;
  text-align: center;
  padding: 20px;
}
#guard-overlay.active { display: flex; }
#guard-overlay .g-icon  { font-size: 56px; }
#guard-overlay .g-msg   { font-size: 18px; font-weight: bold; color: #fff; line-height: 1.5; }
#guard-overlay .g-sub   { font-size: 14px; color: #FFC107; }
#guard-overlay .g-spin  {
  width: 44px; height: 44px;
  border: 5px solid rgba(255,255,255,0.3);
  border-top: 5px solid #FFC107;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-top: 10px;
}
