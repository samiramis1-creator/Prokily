  sessionStorage.setItem('sp',scrollY);
  const isAr=document.documentElement.lang==='ar';
  window.location.href=isAr?'index-fr.html':'index.html';
}
window.addEventListener('load',()=>{const sp=sessionStorage.getItem('sp');if(sp){scrollTo({top:+sp,behavior:'instant'});sessionStorage.removeItem('sp');}});
</script>

</body>
