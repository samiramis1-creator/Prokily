      const num=el.querySelector('.st-n');if(!num)return;
      const idx=[...document.querySelectorAll('.st-n')].indexOf(num);
      const s=STATS[idx];let cur=0;const step=s.val/55;
      const run=()=>{cur=Math.min(cur+step,s.val);num.textContent=(s.dec?cur.toFixed(s.dec):Math.round(cur))+s.suf;if(cur<s.val)requestAnimationFrame(run);};
      run();
    }
    io.unobserve(el);
  });
},{threshold:.15});
