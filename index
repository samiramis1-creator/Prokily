<style>
/* ═══════════════════════════════════════════════════
   BANKILY — Rich Dark Theme
   BG: #030E14  Primary: #0097A7  Green: #00B087
═══════════════════════════════════════════════════ */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;overflow-x:hidden;scrollbar-gutter:stable}
html,body{overflow-x:hidden;width:100%;background-color:#030E14}
body{
  font-family:'Cairo',sans-serif;
  background:#030E14;
  color:#7BBEC8;
  line-height:1.7;
  min-height:100vh;
}
h1,h2,h3,h4,h5,h6,p,a,button,span,div,input,label{font-family:'Cairo',sans-serif}

/* CANVAS */
#cvs{position:fixed;inset:0;z-index:0;pointer-events:none}

/* TOASTS */
#toasts{
position:fixed;bottom:96px;right:14px;
z-index:8000;display:flex;flex-direction:column-reverse;gap:8px;
pointer-events:none;max-width:280px;
}
.toast{
background:rgba(3,14,20,0.95);backdrop-filter:blur(20px);
border:1px solid rgba(0,151,167,.25);
border-left:3px solid #00B8CC;
border-radius:14px;padding:11px 14px;
display:flex;align-items:center;gap:11px;
box-shadow:0 16px 50px rgba(0,0,0,.8);
animation:tIn .4s cubic-bezier(0.23,1,0.32,1),tOut .4s ease 4.4s forwards;
}
@keyframes tIn{from{opacity:0;transform:translateX(-28px)}to{opacity:1;transform:none}}
@keyframes tOut{to{opacity:0;transform:translateX(-28px)}}
.t-av{width:38px;height:38px;border-radius:50%;flex-shrink:0;background:linear-gradient(135deg,#0097A7,#00C99E);display:flex;align-items:center;justify-content:center;font-size:17px}
.t-name{font-size:.8rem;font-weight:700;color:#E8F8F8;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.t-val{font-size:.73rem;color:#00B8CC;font-weight:600}

/* LOADER */
#loader{position:fixed;inset:0;z-index:99999;background:#030E14;display:none;flex-direction:column;align-items:center;justify-content:center;gap:20px}
#loader.on{display:flex}
.ld-ring{width:72px;height:72px;position:relative}
.ld-ring::before{content:’’;position:absolute;inset:0;border-radius:50%;border:3px solid transparent;border-top-color:#00D4E8;animation:spin .8s linear infinite}
.ld-ring::after{content:’’;position:absolute;inset:10px;border-radius:50%;border:3px solid transparent;border-bottom-color:#00B087;animation:spin 1.4s linear infinite reverse}
@keyframes spin{to{transform:rotate(360deg)}}
.ld-txt{color:#00B8CC;font-size:.92rem;font-weight:700;letter-spacing:2px}

/* STRIP */
.strip{
background:rgba(0,151,167,.1);
border-bottom:1px solid rgba(0,151,167,.2);
text-align:center;padding:.44rem 1rem;
font-size:.82rem;color:#00C99E;font-weight:600;
position:relative;overflow:hidden;z-index:200;
}
.strip::after{content:’’;position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(0,201,158,.07),transparent);animation:ss 4s linear infinite}
@keyframes ss{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}

/* NAV */
nav{
position:sticky;top:0;z-index:100;
background:rgba(3,13,18,.93);
backdrop-filter:blur(30px) saturate(180%);
border-bottom:1px solid rgba(0,151,167,.18);
transition:box-shadow .3s;
}
nav.scrolled{box-shadow:0 4px 40px rgba(0,0,0,.7)}
.nav-in{max-width:1280px;margin:0 auto;padding:.8rem 1.5rem;display:flex;justify-content:space-between;align-items:center}
.logo{height:42px;display:block}
.lang-btn{
border:1.5px solid #0097A7;border-radius:50px;
background:transparent;color:#00B8CC;
font-family:‘Cairo’,sans-serif;font-size:.85rem;font-weight:700;
padding:.38rem 1.2rem;cursor:pointer;
transition:all .3s;
}
.lang-btn:hover{background:#0097A7;color:#fff;box-shadow:0 0 20px rgba(0,151,167,.4)}

/* MOBILE CTA */
.mob-bar{display:none;position:fixed;bottom:0;left:0;right:0;z-index:500;padding:10px 14px calc(12px + env(safe-area-inset-bottom));background:linear-gradient(180deg,transparent,#030E14 30%);transition:opacity .35s,transform .35s}
.mob-bar.hide{opacity:0;transform:translateY(100%);pointer-events:none}
.mob-bar button{width:100%;padding:.95rem;border:none;border-radius:14px;background:linear-gradient(135deg,#00C99E,#0097A7);color:#fff;font-family:‘Cairo’,sans-serif;font-size:1.05rem;font-weight:800;cursor:pointer;position:relative;overflow:hidden;box-shadow:0 8px 30px rgba(0,151,167,.5);animation:mbP 2.5s ease-in-out infinite}
.mob-bar button::after{content:’’;position:absolute;top:-50%;left:-60%;width:220%;height:220%;background:linear-gradient(45deg,transparent 30%,rgba(255,255,255,.2) 50%,transparent 70%);animation:shimmer 3.5s infinite}
@keyframes mbP{0%,100%{box-shadow:0 8px 28px rgba(0,151,167,.45),0 0 0 0 rgba(0,151,167,0)}50%{box-shadow:0 14px 45px rgba(0,201,158,.65),0 0 0 12px rgba(0,151,167,.1)}}
@keyframes shimmer{0%{transform:translateX(-100%) rotate(45deg)}100%{transform:translateX(120%) rotate(45deg)}}
@media(max-width:768px){.mob-bar{display:block}body{padding-bottom:76px}}

/* LAYOUT */
.wrap{max-width:1280px;margin:0 auto;padding:0 1.5rem}
.sec{padding:6rem 0;position:relative;z-index:2}
.sec-head{text-align:center;margin-bottom:3.5rem}
.eyebrow{display:inline-flex;align-items:center;gap:.5rem;font-size:.75rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#00B8CC;padding:.35rem 1.1rem;border:1px solid rgba(0,151,167,.25);border-radius:50px;background:rgba(0,151,167,.1);margin-bottom:1rem}
.eyebrow-dot{width:6px;height:6px;border-radius:50%;background:#00D4E8;box-shadow:0 0 8px #00D4E8}
.sec-h{font-size:clamp(1.9rem,4.5vw,3rem);font-weight:900;color:#E8F8F8;margin-bottom:.7rem;line-height:1.18}
.sec-p{color:#3D6E7A;font-size:1rem;max-width:520px;margin:0 auto}
.sec-line{width:50px;height:3px;margin:1.1rem auto 0;border-radius:2px;background:linear-gradient(90deg,transparent,#0097A7,transparent)}
.rv{opacity:0;transform:translateY(26px);transition:opacity .75s cubic-bezier(0.23,1,0.32,1),transform .75s cubic-bezier(0.23,1,0.32,1)}
.rv.v{opacity:1;transform:none}

/* HERO */
.hero{min-height:100svh;display:flex;align-items:center;position:relative;overflow:hidden;padding:5rem 0 3rem;z-index:2}

/* Orb glows */
.hero-orbs{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.orb{position:absolute;border-radius:50%;filter:blur(90px);animation:orbD 14s ease-in-out infinite}
.orb1{width:600px;height:600px;top:-180px;right:-140px;background:radial-gradient(ellipse,rgba(0,151,167,.28) 0%,transparent 70%);animation-duration:16s}
.orb2{width:450px;height:450px;bottom:-120px;left:-90px;background:radial-gradient(ellipse,rgba(0,176,135,.2) 0%,transparent 70%);animation-duration:11s;animation-delay:-6s}
.orb3{width:320px;height:320px;top:40%;left:45%;background:radial-gradient(ellipse,rgba(0,212,232,.1) 0%,transparent 70%);animation-duration:20s;animation-delay:-10s}
@keyframes orbD{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(22px,-34px) scale(1.06)}66%{transform:translate(-18px,22px) scale(.94)}}

/* Grid */
.hero-grid{position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(rgba(0,151,167,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(0,151,167,.05) 1px,transparent 1px);background-size:55px 55px;mask-image:radial-gradient(ellipse 80% 65% at 50% 50%,black 20%,transparent 80%)}

.hero-in{position:relative;z-index:2;max-width:940px;margin:0 auto;text-align:center;padding:0 1.5rem}

/* Badge */
.h-badge{display:inline-flex;align-items:center;gap:.6rem;padding:.44rem 1.5rem;margin-bottom:1.8rem;background:linear-gradient(135deg,rgba(0,151,167,.15),rgba(0,176,135,.08));border:1px solid rgba(0,151,167,.4);border-radius:50px;color:#00B8CC;font-size:.88rem;font-weight:700;backdrop-filter:blur(10px);animation:bPulse 3.5s ease-in-out infinite}
@keyframes bPulse{0%,100%{box-shadow:0 0 0 0 rgba(0,151,167,0)}60%{box-shadow:0 0 0 10px rgba(0,151,167,.08)}}
.bdot{width:8px;height:8px;border-radius:50%;background:#00D4E8;box-shadow:0 0 10px #00D4E8;animation:bdB 1.6s ease-in-out infinite}
@keyframes bdB{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.2;transform:scale(.6)}}

/* H1 */
.hero h1{font-size:clamp(2.5rem,9vw,5.5rem);font-weight:900;line-height:1.05;margin-bottom:1.4rem;letter-spacing:-.5px}
.h1a{display:block;color:#E8F8F8}
.h1b{display:block;background:linear-gradient(135deg,#00C99E 0%,#00D4E8 40%,#00B8CC 70%,#7DD3FC 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:h1g 4s ease-in-out infinite alternate}
@keyframes h1g{from{filter:drop-shadow(0 0 18px rgba(0,151,167,.5))}to{filter:drop-shadow(0 0 55px rgba(0,201,158,.8))}}

.hero-sub{font-size:clamp(1rem,2.5vw,1.22rem);color:#7BBEC8;max-width:640px;margin:0 auto 2.8rem;opacity:.9}

/* Prize bar */
.prize-bar{display:inline-flex;align-items:stretch;background:rgba(3,14,20,.9);backdrop-filter:blur(20px);border:1px solid rgba(0,151,167,.22);border-radius:20px;overflow:hidden;margin-bottom:3rem;box-shadow:0 20px 60px rgba(0,0,0,.8),inset 0 1px 0 rgba(0,212,232,.08)}
.pb{padding:1.1rem 1.8rem;display:flex;flex-direction:column;align-items:center;gap:.3rem}
.pb+.pb{border-right:1px solid rgba(0,151,167,.2)}
.pb-l{font-size:.68rem;color:#3D6E7A;font-weight:700;letter-spacing:1.5px;text-transform:uppercase}
.pb-v{font-size:clamp(1.35rem,3.5vw,2.1rem);font-weight:900;color:#FCD34D;line-height:1;white-space:nowrap}
.pb-v.sm{font-size:clamp(1rem,2.5vw,1.55rem);color:#00B8CC}
@media(max-width:520px){.prize-bar{flex-direction:column;max-width:260px;margin-left:auto;margin-right:auto}.pb+.pb{border-right:none;border-top:1px solid rgba(0,151,167,.2)}}

/* ═══════ CTA SPECTACULAR ═══════ */
.cta-wrap{display:flex;flex-direction:column;align-items:center;gap:1rem}
.cta-stage{position:relative;display:inline-block;padding:40px}

.cta-ring{position:absolute;inset:0;border-radius:60px;border:1.5px solid rgba(0,212,232,.45);animation:ringP 2.5s ease-out infinite}
.cta-ring:nth-child(2){animation-delay:.83s;inset:-8px;border-color:rgba(0,176,135,.32)}
.cta-ring:nth-child(3){animation-delay:1.66s;inset:-16px;border-color:rgba(0,212,232,.18)}
@keyframes ringP{0%{opacity:.9;transform:scale(.9)}100%{opacity:0;transform:scale(1.35)}}

.orb-dot{position:absolute;width:8px;height:8px;border-radius:50%;background:#00D4E8;box-shadow:0 0 12px #00D4E8;top:50%;left:50%;animation:dotO 4s linear infinite}
.orb-dot:nth-child(4){animation-delay:-1.33s;background:#00C99E;box-shadow:0 0 12px #00C99E}
.orb-dot:nth-child(5){animation-delay:-2.66s;background:#FCD34D;box-shadow:0 0 12px #FCD34D}
@keyframes dotO{0%{transform:rotate(0deg) translateX(68px) scale(1)}50%{transform:rotate(180deg) translateX(68px) scale(1.5)}100%{transform:rotate(360deg) translateX(68px) scale(1)}}

.cta-btn{
position:relative;z-index:2;overflow:hidden;
padding:1.2rem 4.2rem;border:none;border-radius:50px;
background:linear-gradient(135deg,#00C99E 0%,#0097A7 55%,#006070 100%);
background-size:200% 100%;
color:#fff;font-family:‘Cairo’,sans-serif;
font-size:1.22rem;font-weight:900;letter-spacing:.5px;
cursor:pointer;text-shadow:0 1px 3px rgba(0,0,0,.3);
box-shadow:0 0 0 0 rgba(0,212,232,.5),0 12px 44px rgba(0,151,167,.65),0 5px 0 rgba(0,60,80,.9),inset 0 1px 0 rgba(255,255,255,.25);
animation:ctaM 2.8s ease-in-out infinite;
transition:transform .25s,box-shadow .25s;
}
@keyframes ctaM{
0%,100%{background-position:0 50%;box-shadow:0 0 0 0 rgba(0,212,232,.4),0 12px 44px rgba(0,151,167,.6),0 5px 0 rgba(0,60,80,.9),inset 0 1px 0 rgba(255,255,255,.25)}
50%{background-position:100% 50%;box-shadow:0 0 0 20px rgba(0,151,167,.08),0 20px 65px rgba(0,201,158,.8),0 5px 0 rgba(0,60,80,.9),inset 0 1px 0 rgba(255,255,255,.3)}
}
.cta-btn::before{content:’’;position:absolute;top:-50%;left:-60%;width:220%;height:220%;background:linear-gradient(45deg,transparent 30%,rgba(255,255,255,.28) 50%,transparent 70%);animation:shimmer 3s infinite}
.cta-btn::after{content:’’;position:absolute;bottom:-1px;left:12%;right:12%;height:2px;background:linear-gradient(90deg,transparent,rgba(0,212,232,.9),transparent);border-radius:0 0 50px 50px}
.cta-btn:hover{transform:translateY(-6px) scale(1.07);box-shadow:0 0 0 24px rgba(0,151,167,.07),0 28px 80px rgba(0,201,158,.85),0 6px 0 rgba(0,40,60,.9);animation:none}
.cta-btn:active{transform:translateY(-2px) scale(1.02)}
.cta-note{font-size:.8rem;color:#3D6E7A;letter-spacing:.3px}

/* PRIZES */
.prizes-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem}
@media(max-width:900px){.prizes-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.prizes-grid{gap:1rem}}
.pc{border-radius:20px;overflow:hidden;background:#082130;border:1px solid rgba(0,151,167,.2);transition:all .45s cubic-bezier(0.23,1,0.32,1);opacity:0;transform:translateY(22px) scale(.97);cursor:pointer}
.pc.v{opacity:1;transform:none}
.pc:hover{border-color:rgba(0,176,135,.55);transform:translateY(-12px) scale(1.03);box-shadow:0 8px 40px rgba(0,151,167,.4),0 20px 60px rgba(0,0,0,.8)}
.pc-img{overflow:hidden;height:160px;position:relative}
@media(max-width:480px){.pc-img{height:125px}}
.pc-img img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .55s ease}
.pc:hover .pc-img img{transform:scale(1.1)}
.pc-img::after{content:’’;position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(0,0,0,.65) 100%)}
.pc-body{padding:1rem 1.1rem 1.2rem;background:linear-gradient(180deg,transparent,rgba(0,151,167,.08))}
.pc-icon{font-size:1.3rem;margin-bottom:.3rem}
.pc-name{font-size:.9rem;font-weight:700;color:#E8F8F8}

/* COUNTDOWN */
.cd-sec{background:linear-gradient(180deg,transparent,rgba(0,151,167,.06),transparent)}
.cd-box{max-width:840px;margin:0 auto;background:rgba(5,20,28,.9);backdrop-filter:blur(30px);border:1px solid rgba(0,151,167,.2);border-radius:28px;padding:3.5rem 2rem;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.8);position:relative;overflow:hidden}
.cd-box::before{content:’’;position:absolute;top:-1px;left:12%;right:12%;height:1px;background:linear-gradient(90deg,transparent,#00B8CC,transparent)}
.cd-box::after{content:’’;position:absolute;inset:0;background:radial-gradient(ellipse 60% 40% at 50% 0%,rgba(0,151,167,.08) 0%,transparent 60%);pointer-events:none}
.cd-top{margin-bottom:2.2rem;position:relative;z-index:1}
.cd-label{font-size:.82rem;color:#3D6E7A;letter-spacing:2px;text-transform:uppercase;margin-bottom:.6rem}
.cd-badge{display:inline-flex;align-items:center;gap:.55rem;background:linear-gradient(135deg,#F59E0B,#D97706);color:#1A0A00;font-size:.88rem;font-weight:800;padding:.42rem 1.4rem;border-radius:50px;box-shadow:0 4px 20px rgba(245,158,11,.45)}
.cd-row{display:flex;justify-content:center;align-items:flex-start;gap:1.2rem;flex-wrap:wrap;position:relative;z-index:1}
.cd-u{display:flex;flex-direction:column;align-items:center;gap:.55rem}
.cd-card{background:#05141C;border:1px solid rgba(0,151,167,.2);border-radius:16px;padding:1.3rem 1.8rem;min-width:92px;position:relative;overflow:hidden;box-shadow:inset 0 1px 0 rgba(0,212,232,.05),0 8px 30px rgba(0,0,0,.6)}
.cd-card::before{content:’’;position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,212,232,.05) 0%,transparent 50%)}
.cd-card::after{content:’’;position:absolute;top:50%;left:8%;right:8%;height:1px;background:rgba(0,0,0,.6);z-index:0}
.cd-n{font-size:3.2rem;font-weight:900;line-height:1;font-variant-numeric:tabular-nums;color:#E8F8F8;text-shadow:0 0 30px rgba(0,212,232,.55);position:relative;z-index:1}
.cd-n.tick{animation:cdF .3s ease}
@keyframes cdF{0%{transform:translateY(-6px);opacity:.3}100%{transform:none;opacity:1}}
.cd-l{font-size:.68rem;color:#3D6E7A;letter-spacing:1.5px;text-transform:uppercase;font-weight:700}
.cd-sep{font-size:3rem;color:#0097A7;font-weight:900;opacity:.4;align-self:center;margin-bottom:1.9rem;animation:sb 1s step-start infinite}
@keyframes sb{50%{opacity:0}}
@media(max-width:580px){.cd-card{min-width:66px;padding:.9rem 1rem}.cd-n{font-size:2.3rem}.cd-sep{display:none}}

/* STATS */
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
@media(max-width:600px){.stats-row{grid-template-columns:1fr;gap:1rem}}
.st{padding:2.5rem 1.5rem;text-align:center;background:#082130;border:1px solid rgba(0,151,167,.2);border-radius:24px;position:relative;overflow:hidden;transition:all .45s cubic-bezier(0.23,1,0.32,1);opacity:0;transform:translateY(18px)}
.st.v{opacity:1;transform:none}
.st:hover{border-color:rgba(0,176,135,.5);box-shadow:0 8px 40px rgba(0,151,167,.35);transform:translateY(-6px)}
.st::before{content:’’;position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,#00B8CC,transparent);opacity:0;transition:.4s}
.st:hover::before{opacity:1}
.st-ico{font-size:2.4rem;margin-bottom:.7rem;display:block}
.st-n{font-size:2.8rem;font-weight:900;line-height:1.1;margin-bottom:.4rem;background:linear-gradient(135deg,#E8F8F8 0%,#00B8CC 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;font-variant-numeric:tabular-nums}
.st-n.bump{animation:stB .4s cubic-bezier(0.23,1,0.32,1)}
@keyframes stB{0%{transform:scale(1)}50%{transform:scale(1.22)}100%{transform:scale(1)}}
.st-l{font-size:.88rem;color:#3D6E7A;font-weight:600}

/* HOW */
.how-bg{background:linear-gradient(180deg,transparent,rgba(0,151,167,.05),transparent)}
.how-row{display:grid;grid-template-columns:repeat(3,1fr);gap:1.8rem;position:relative}
.how-row::before{content:’’;position:absolute;top:54px;right:calc(100%/6);width:calc(100%*2/3);height:1px;background:linear-gradient(to left,transparent,#0097A7,transparent);opacity:.28;pointer-events:none}
@media(max-width:760px){.how-row{grid-template-columns:1fr;gap:1.2rem}.how-row::before{display:none}}
.hw{text-align:center;padding:2.5rem 1.8rem;background:#082130;border:1px solid rgba(0,151,167,.2);border-radius:22px;transition:all .45s cubic-bezier(0.23,1,0.32,1);opacity:0;transform:translateY(22px)}
.hw.v{opacity:1;transform:none}
.hw:hover{border-color:rgba(0,176,135,.5);box-shadow:0 8px 40px rgba(0,151,167,.3);transform:translateY(-9px)}
.hw-n{width:56px;height:56px;border-radius:14px;background:linear-gradient(135deg,#00C99E,#0097A7);color:#fff;font-size:1.5rem;font-weight:900;display:flex;align-items:center;justify-content:center;margin:0 auto 1.4rem;box-shadow:0 8px 25px rgba(0,151,167,.5)}
.hw-h{font-size:1.05rem;font-weight:700;color:#E8F8F8;margin-bottom:.55rem}
.hw-p{font-size:.88rem;color:#3D6E7A;line-height:1.65}

/* WINNERS */
.ticker-rail{overflow:hidden;border-radius:14px;background:#082130;border:1px solid rgba(0,151,167,.2);margin-bottom:2rem}
.ticker-tr{display:flex;gap:3rem;white-space:nowrap;padding:.85rem 1rem;animation:tickS 36s linear infinite}
.ticker-tr:hover{animation-play-state:paused}
@keyframes tickS{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
