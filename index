/* Canvas — particles + connections + shooting stars */
(function(){
  const c=document.getElementById('cvs'),ctx=c.getContext('2d');
  let pts=[],sh=[];
  const COLS=['0,212,232','0,201,158','0,184,204'];

  function resize(){
    c.width=innerWidth;c.height=innerHeight;pts=[];
    const n=Math.min(85,Math.floor(c.width*c.height/12000));
    for(let i=0;i<n;i++)pts.push({
      x:Math.random()*c.width,y:Math.random()*c.height,
      vx:(Math.random()-.5)*.4,vy:(Math.random()-.5)*.4,
      r:Math.random()*1.8+.3,a:Math.random()*.6+.15,
      ci:Math.floor(Math.random()*3)
    });
  }
  function addSh(){sh.push({x:Math.random()*c.width,y:Math.random()*c.height*.3,vx:5+Math.random()*6,vy:2.5+Math.random()*3,a:.9,len:0,maxLen:100+Math.random()*140})}
  setInterval(addSh,3800);

  function draw(){
    ctx.clearRect(0,0,c.width,c.height);
    pts.forEach(p=>{
      p.x+=p.vx;p.y+=p.vy;
      if(p.x<0||p.x>c.width)p.vx*=-1;
      if(p.y<0||p.y>c.height)p.vy*=-1;
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle=`rgba(${COLS[p.ci]},${p.a})`;ctx.fill();
    });
