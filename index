function flip(el,v){if(el.textContent===v)return;el.classList.remove('tick');void el.offsetWidth;el.textContent=v;el.classList.add('tick');}
function tick(){
  let diff=cdEnd-Date.now();
  if(diff<=0){cdEnd=eom();diff=cdEnd-Date.now();}
  flip(CD.d,pad(Math.floor(diff/864e5)));
  flip(CD.h,pad(Math.floor((diff%864e5)/36e5)));
  flip(CD.m,pad(Math.floor((diff%36e5)/6e4)));
  flip(CD.s,pad(Math.floor((diff%6e4)/1e3)));
